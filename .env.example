# Copy this file to .env for local deployment.
# Keep .env out of Git. It may contain local paths and future secrets.

KEUMJM_HOST=0.0.0.0
KEUMJM_PORT=8515

# lan: allow localhost, private IPs, and KEUMJM_ALLOWED_CIDRS only.
# internet: allow all client IPs. Use only behind HTTPS/auth/reverse proxy.
# Render/public deployment should set KEUMJM_ACCESS_MODE=internet.
KEUMJM_ACCESS_MODE=lan
KEUMJM_ALLOWED_CIDRS=

# Keep docs on for LAN testing. Turn off before public internet exposure.
KEUMJM_ENABLE_DOCS=true
ENABLE_MACRO=false

# Login/session settings.
KEUMJM_AUTH_ENABLED=true
# First registered account becomes admin. Set false after creating users if self-registration is not desired.
KEUMJM_AUTH_ALLOW_REGISTRATION=true
KEUMJM_AUTH_COOKIE_SECURE=false
KEUMJM_AUTH_SESSION_DAYS=14
# Required with Turso/remote DB storage; set on Render so sessions never depend on local files.
KEUMJM_AUTH_SECRET=
KEUMJM_AUTH_DB_PATH=data/users/auth.sqlite
KEUMJM_AUTH_SECRET_PATH=data/users/session_secret.key
# Optional: create or update an admin account from environment variables.
# Useful on Render without a persistent disk, where SQLite files can disappear on redeploy/restart.
KEUMJM_BOOTSTRAP_ADMIN_USERNAME=
KEUMJM_BOOTSTRAP_ADMIN_PASSWORD=

# Compress large HTML responses for LAN/mobile clients.
# Lower level uses less CPU; higher level sends fewer bytes.
KEUMJM_GZIP_MINIMUM_SIZE=1024
KEUMJM_GZIP_COMPRESSLEVEL=5

# Optional runtime data locations.
# On Render with a persistent disk mounted at /var/data, use:
# KEUMJM_AUTH_DB_PATH=/var/data/users/auth.sqlite
# KEUMJM_AUTH_SECRET_PATH=/var/data/users/session_secret.key
# KEUMJ_PORTFOLIO_DB_DIR=/var/data/portfolio
# KEUMJ_SP500_DB_DIR=/var/data/sp500_shared_db
KEUMJ_SP500_DB_DIR=data/sp500_shared_db
KEUMJ_PORTFOLIO_DB_DIR=data/portfolio

# Optional external app DB. If set, users and portfolio_trades are stored here.
# Auth tokens are optional: set them only if your Turso/libSQL database requires one.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Same values can also be provided with app-specific names:
# KEUMJM_DATABASE_URL=
# KEUMJM_DATABASE_AUTH_TOKEN=

# Runtime calculation DBs. When set, dashboards read S&P 500/news/fundamentals
# and macro series from Turso instead of local SQLite/LFS files.
# Auth tokens are optional only for databases that allow URL-only access.
# If Render logs mention "empty JWT token" or HTTP 401, set the matching token.
KEUMJ_SP500_DATABASE_URL=
KEUMJ_SP500_DATABASE_AUTH_TOKEN=
KEUMJ_MACRO_DATABASE_URL=
KEUMJ_MACRO_DATABASE_AUTH_TOKEN=
# Use Turso/libSQL embedded replicas for fast local reads while writes still go
# to the remote primary DB. On Render with a persistent disk, set the replica
# dir under /var/data so the first sync survives restarts.
KEUMJ_TURSO_EMBEDDED_REPLICA=true
KEUMJ_TURSO_REPLICA_DIR=data/turso_replicas
# KEUMJ_TURSO_REPLICA_DIR=/var/data/turso_replicas
KEUMJ_TURSO_REPLICA_SYNC_SECONDS=300
# Optional per-DB overrides:
# KEUMJ_SP500_REPLICA_PATH=/var/data/turso_replicas/sp500_shared_prices_replica.sqlite
# KEUMJ_MACRO_REPLICA_PATH=/var/data/turso_replicas/macro_prices_replica.sqlite
# Render Cron command for direct daily incremental refresh:
# python scripts/refresh_turso_daily.py
# Local fallback upload after a failed Render refresh:
# refresh_turso_data.cmd upload-local

# Render/runtime performance.
# On Render this defaults to true and disables very heavy S&P 500-wide relative features.
KEUMJM_FORECAST_LIGHT_MODE=
KEUMJ_STOCK_RELATIVE_FEATURES=
# On Render these default to false so deployments can omit large CSV fallback files.
# Local development defaults to true.
KEUMJ_SP500_LOCAL_CSV_FALLBACK=
KEUMJ_SP500_SYNTHETIC_FALLBACK=

# Render/runtime news lab performance.
KEUMJM_NEWS_LIGHT_MODE=false
KEUMJM_NEWS_MAX_ARTICLES=
KEUMJM_NEWS_MAX_LOOKBACK_DAYS=
KEUMJM_NEWS_MAX_HORIZON_DAYS=
KEUMJM_NEWS_MAX_TOP_N=
KEUMJM_NEWS_MAX_TOPIC_COUNT=
