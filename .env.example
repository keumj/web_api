# Copy this file to .env for local deployment.
# Keep .env out of Git. It may contain local paths and future secrets.

KEUMJM_HOST=0.0.0.0
KEUMJM_PORT=8515

# lan: allow localhost, private IPs, and KEUMJM_ALLOWED_CIDRS only.
# internet: allow all client IPs. Use only behind HTTPS/auth/reverse proxy.
KEUMJM_ACCESS_MODE=lan
KEUMJM_ALLOWED_CIDRS=

# Keep docs on for LAN testing. Turn off before public internet exposure.
KEUMJM_ENABLE_DOCS=true

# Login/session settings.
KEUMJM_AUTH_ENABLED=true
# First registered account becomes admin. Set false after creating users if self-registration is not desired.
KEUMJM_AUTH_ALLOW_REGISTRATION=true
KEUMJM_AUTH_COOKIE_SECURE=false
KEUMJM_AUTH_SESSION_DAYS=14
KEUMJM_AUTH_DB_PATH=data/users/auth.sqlite
KEUMJM_AUTH_SECRET_PATH=data/users/session_secret.key
# Optional: create or update an admin account from environment variables.
# Useful on Render without a persistent disk, where SQLite files can disappear on redeploy/restart.
KEUMJM_BOOTSTRAP_ADMIN_USERNAME=
KEUMJM_BOOTSTRAP_ADMIN_PASSWORD=

# Compress large HTML responses for LAN/mobile clients.
# Lower level uses less CPU; higher level sends fewer bytes.
KEUMJM_GZIP_MINIMUM_SIZE=1024
KEUMJM_GZIP_COMPRESSLEVEL=5

# Optional runtime data locations.
# On Render with a persistent disk mounted at /var/data, use:
# KEUMJM_AUTH_DB_PATH=/var/data/users/auth.sqlite
# KEUMJM_AUTH_SECRET_PATH=/var/data/users/session_secret.key
# KEUMJ_PORTFOLIO_DB_DIR=/var/data/portfolio
# KEUMJ_SP500_DB_DIR=/var/data/sp500_shared_db
KEUMJ_SP500_DB_DIR=data/sp500_shared_db
KEUMJ_PORTFOLIO_DB_DIR=data/portfolio

# Render/runtime performance.
# On Render this defaults to true and disables very heavy S&P 500-wide relative features.
KEUMJM_FORECAST_LIGHT_MODE=
KEUMJ_STOCK_RELATIVE_FEATURES=

# Render/runtime news lab performance.
KEUMJM_NEWS_LIGHT_MODE=
KEUMJM_NEWS_MAX_ARTICLES=
KEUMJM_NEWS_MAX_LOOKBACK_DAYS=
KEUMJM_NEWS_MAX_HORIZON_DAYS=
KEUMJM_NEWS_MAX_TOP_N=
KEUMJM_NEWS_MAX_TOPIC_COUNT=
